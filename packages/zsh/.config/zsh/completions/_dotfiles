#compdef dotfiles

_dotfiles() {
  local subcommand="${words[2]:-}"
  local previous_word="${words[CURRENT-1]:-}"
  local -a commands sources doctor_options outdated_options claude_settings_options install_options

  commands=(
    install:"Link dotfiles and install managed tools"
    outdated:"Check Homebrew, mise, and sheldon updates"
    doctor:"Diagnose local dotfiles symlink health"
    claude-settings:"Generate Claude Code user settings"
    help:"Show help"
  )
  sources=(
    brew:"Homebrew outdated"
    mise:"mise outdated"
    sheldon:"sheldon plugin pinned revs"
  )
  outdated_options=(
    --refresh:"Refresh update metadata before supported sources"
    --list:"Show available sources"
    --help:"Show outdated help"
  )
  doctor_options=(
    --help:"Show doctor help"
  )
  install_options=(
    --skip-confirmation:"Do not prompt before running official remote installer scripts"
  )
  claude_settings_options=(
    --help:"Show Claude settings help"
  )

  if (( CURRENT == 2 )); then
    _describe -t commands "dotfiles command" commands
    return
  fi

  case "$subcommand" in
    install)
      if [[ "$previous_word" == -- ]]; then
        return
      fi
      _describe -t options "install option" install_options
      ;;
    outdated)
      if [[ "$PREFIX" == -* ]]; then
        _describe -t options "outdated option" outdated_options
        return
      fi
      _describe -t sources "outdated source" sources
      ;;
    doctor)
      if [[ "$PREFIX" == -* ]]; then
        _describe -t options "doctor option" doctor_options
      fi
      ;;
    claude-settings)
      if [[ "$PREFIX" == -* ]]; then
        _describe -t options "Claude settings option" claude_settings_options
      fi
      ;;
    help|--help|-h)
      ;;
    *)
      _describe -t commands "dotfiles command" commands
      ;;
  esac
}

_dotfiles "$@"
