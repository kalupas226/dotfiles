# Minimal safety & reproducibility defaults for local use
ignore-scripts=true       # Block install-time scripts by default (enable per-need)
save-exact=true           # Pin exact versions when adding deps
engine-strict=true        # Prevent installing on unsupported node/npm engines
audit=true                # Enable vulnerability scanning on install
audit-level=critical      # Fail audit only for critical severity
min-release-age=7         # Skip packages published within the last 7 days (supply chain defense)
fund=false                # Quieter output (optional)
progress=false            # Less noisy progress bar (optional)
