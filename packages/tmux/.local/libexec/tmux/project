#!/usr/bin/env bash

set -euo pipefail

usage() {
    cat <<'EOF'
Usage:
  ~/.local/libexec/tmux/project

Select a ghq repository with fzf, then switch to a tmux session for it.
If the session does not exist, this helper creates it with a main window from
the selected repository root.
EOF
}

die() {
    printf 'tmux/project: %s\n' "$*" >&2
    exit 1
}

require_cmd() {
    command -v "$1" >/dev/null 2>&1 || die "required command not found: $1"
}

project_label_for_path() {
    local project_dir="$1"
    local organization
    local repository

    organization="$(basename -- "$(dirname -- "$project_dir")")"
    repository="$(basename -- "$project_dir")"

    if [[ -n "$organization" && "$organization" != "." && "$organization" != "/" ]]; then
        printf '%s/%s\n' "$organization" "$repository"
    else
        printf '%s\n' "$repository"
    fi
}

project_records() {
    local project_dir
    local label

    while IFS= read -r project_dir; do
        [[ -n "$project_dir" ]] || continue
        label="$(project_label_for_path "$project_dir")"
        printf '%s\t%s\n' "$label" "$project_dir"
    done
}

select_project_dir() {
    local preview
    local selected_record
    local selected_dir

    preview="printf '%s\n' {} | awk -F \"\t\" '{ print \"Path:\"; print \$2 }'"
    selected_record="$(
        ghq list -p |
            project_records |
            fzf \
                --prompt='project> ' \
                --delimiter=$'\t' \
                --with-nth=1 \
                --preview="$preview" \
                --preview-window=down:3:wrap
    )" || return 1
    [[ -n "$selected_record" ]] || return 1

    selected_dir="${selected_record#*$'\t'}"
    [[ "$selected_dir" != "$selected_record" ]] || die "selected record is missing path: $selected_record"
    [[ -n "$selected_dir" ]] || return 1
    [[ -d "$selected_dir" ]] || die "selected path is not a directory: $selected_dir"

    printf '%s\n' "$selected_dir"
}

session_name_for_path() {
    local project_dir="$1"
    local name

    name="$(project_label_for_path "$project_dir")"
    name="$(printf '%s' "$name" | tr -cs '[:alnum:]_.-' '_' | sed 's/^_*//; s/_*$//')"
    [[ -n "$name" ]] || die "could not derive session name from: $project_dir"

    printf '%s\n' "$name"
}

session_id_for_name() {
    local session_name="$1"

    { tmux list-sessions -F '#{session_name}	#{session_id}' 2>/dev/null || true; } |
        awk -F '\t' -v name="$session_name" '$1 == name { print $2; exit }'
}

open_session() {
    local session_id="$1"

    if [[ -n "${TMUX:-}" ]]; then
        tmux switch-client -t "$session_id"
    else
        tmux attach-session -t "$session_id"
    fi
}

main() {
    local project_dir
    local session_name
    local session_id

    case "${1:-}" in
        -h|--help|help)
            usage
            return 0
            ;;
    esac

    require_cmd ghq
    require_cmd fzf
    require_cmd tmux

    project_dir="$(select_project_dir)" || return 0
    session_name="$(session_name_for_path "$project_dir")"
    session_id="$(session_id_for_name "$session_name")"

    if [[ -z "$session_id" ]]; then
        session_id="$(tmux new-session -d -P -F '#{session_id}' -s "$session_name" -n main -c "$project_dir")"
        [[ -n "$session_id" ]] || session_id="$session_name"
    fi

    open_session "$session_id"
}

main "$@"
